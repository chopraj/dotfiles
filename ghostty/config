#
# --- your current config ---
#
theme = Kanagawa Wave
#theme = GitHub Dark High Contrast
#theme = GitHub Light High Contrast

keybind = shift+enter=text:\n
font-family = Berkeley Mono
adjust-cell-height = 2
background-opacity = 1
#background-opacity = 0.9
background-blur = true

keybind = cmd+shift+j=new_split:right
keybind = cmd+j=new_split:down

keybind = cmd+d=unbind
keybind = cmd+shift+d=unbind
keybind = cmd+shift+p=unbind
keybind = cmd+w=unbind
keybind = cmd+z=unbind

# --- make cmd+shift+w close only the focused pane/split ---
keybind = cmd+shift+w=close_surface

#macos-titlebar-style = hidden
#window-decoration = auto
window-padding-x = 2
window-padding-y = 2
window-padding-balance = true

#custom-shader = ~/.config/ghostty/shaders/glitchy.glsl
#custom-shader = ~/.config/ghostty/shaders/bettercrt.glsl
